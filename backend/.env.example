# ChromaDB Configuration (Local - Default)
CHROMA_DB_PATH=./data/chroma_db

# ChromaDB Cloud Configuration (Optional - Uncomment to use)
# CHROMA_HOST=api.trychroma.com
# CHROMA_API_KEY=your_chroma_api_key
# CHROMA_TENANT=your_tenant_id
# CHROMA_DATABASE=KizunaX

# SQLite Database (Legacy - will be replaced by MongoDB)
SQLITE_DB_PATH=./data/metadata.db

# File Upload
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=pdf,docx,txt,png,jpg,jpeg

# CORS
CORS_ORIGINS=http://localhost:3000

# AI Processing
CATEGORIZATION_CONFIDENCE_THRESHOLD=0.7
EMBEDDING_DIMENSION=1536
LOCAL_EMBEDDING_DIMENSION=384

# Cache
ENABLE_CACHE=true
CACHE_TTL=300

# Application
APP_NAME=KizunaX
APP_VERSION=2.0.0
DEBUG=true

# Google Drive OAuth (optional — for one-way push mirror)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/integrations/google/callback

# Notion OAuth (optional — for one-way push mirror)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/api/integrations/notion/callback
